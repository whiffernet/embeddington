# claudeGraph runtime config.
#
# Copy to .env (in this same directory) and fill in your values:
#   cp .env.example .env
#
# server.py loads this file at startup via python-dotenv. Process env vars
# (e.g. from claude_desktop_config.json) override these values, so this
# file is purely for local convenience — no behavior change if you'd
# rather put everything in the JSON.
#
# DO NOT commit .env to git. Gitignored at the package level.

# --- Service endpoints ----------------------------------------------------
# Point these at YOUR Qdrant + ArangoDB + LlamaIndex /embed.
# If you're running on the same machine as the services, localhost works.
# If MCP is on a different LAN host, use the LAN hostname.
QDRANT_URL=http://localhost:6333
ARANGO_URL=http://localhost:8529
EMBED_URL=http://localhost:8100/embed

# --- Arango credentials ---------------------------------------------------
# The user must be RO-scoped to the ServiceNow KG collections
# (entities_v2 / relationships_v2) with explicit deny on every other
# collection. Graph traversal over servicenow_graph_v2 is authorized via
# grants on its underlying collections.
ARANGO_DATABASE=knowledge_graph
ARANGO_USER=arango_reader
ARANGO_PASSWORD=

# --- Optional tuning ------------------------------------------------------
# HTTP timeout for outbound calls (seconds).
# CLAUDEGRAPH_TIMEOUT=30
