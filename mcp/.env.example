# embeddington MCP server config.
#
# Copy to .env in this directory and fill in your values:
#   cp .env.example .env
#
# server.py loads this file at startup via python-dotenv. Process env vars
# (e.g. from claude_desktop_config.json or .mcp.json) override these values.
#
# DO NOT commit .env. It is gitignored at the package level.

# --- Service endpoints ----------------------------------------------------
QDRANT_URL=http://localhost:6333
ARANGO_URL=http://localhost:8529
EMBED_URL=http://localhost:8100/embed

# --- Arango credentials ---------------------------------------------------
# This is YOUR local ArangoDB, started by consumer/docker-compose.yml with the
# password you set in consumer/.env. `root` here is your own container's root;
# no shared credential ships with this repo.
ARANGO_DATABASE=technology_kg
ARANGO_USER=root
ARANGO_PASSWORD=
