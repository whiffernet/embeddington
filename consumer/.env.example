# Copy to `.env` and set a password before `docker compose up -d`.
# This is the root password for your LOCAL ArangoDB; the consumer CLI uses it to restore
# and query the imported knowledge graph. Choose any value.
ARANGO_ROOT_PASSWORD=change-me

# Arango memory ceiling — drives BOTH the container's hard memory limit and Arango's
# internal cache/query sizing (block cache, edge cache, AQL query limits are all sized
# as if the host had exactly this much RAM). Without it, Arango sizes those to a fraction
# of your TOTAL host RAM and can reserve tens of GB for a <1 GB dataset.
#
# The shared knowledge graph is ~0.8 GB of live data. Guidance (measured):
#   4G  (default) — imports and queries run fine; ~0.5 GB block cache, so the graph is
#                   served partly from disk + OS page cache (still snappy on an SSD).
#   6G            — full in-memory residency of the whole graph (~1.2 GB block cache).
#   8G+           — only worth it if you run many concurrent queries; diminishing returns.
# 4G is the practical floor — smaller shrinks Arango's write buffers enough to slow the
# first-run baseline import. The whole stack (Arango + Qdrant + the bge-m3 embed service)
# wants ~16 GB of host RAM regardless of this value.
ARANGO_MEMORY_CAP=4G
